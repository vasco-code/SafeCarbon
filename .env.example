# Projeto Supabase do SafeCarbon (separado do Conecta Pecuária,
# mesma organização/infra self-hosted da Safe Trace).
VITE_SUPABASE_URL=https://supabase.safetrace.com.br
VITE_SUPABASE_ANON_KEY=

# Credenciais de serviço usadas pelas Edge Functions para obter token da SafeGisTrace.
SAFEGISTRACE_SERVICE_CLIENT_ID=
SAFEGISTRACE_SERVICE_CLIENT_SECRET=

# Endpoint/credenciais da camada de blockchain da Safe Trace (ver
# docs/04-arquitetura-tecnica-integracoes.md — contrato a confirmar).
BLOCKCHAIN_ADAPTER_ENDPOINT=
BLOCKCHAIN_ADAPTER_API_KEY=
